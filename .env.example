# Client-safe values. Expo embeds EXPO_PUBLIC_* values in the app bundle.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Required by native clients outside an Expo development session. Use an absolute HTTPS URL.
EXPO_PUBLIC_API_URL=

# Server-only values. Configure these in the API deployment environment only.
# Never prefix service-role or OpenAI keys with EXPO_PUBLIC_.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
OPENAI_API_KEY=
